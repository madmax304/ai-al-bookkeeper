# Plaid credentials (get from https://dashboard.plaid.com/developers/keys)
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox

# Google Sheets (from your Service Account JSON key file)
GOOGLE_SERVICE_ACCOUNT_EMAIL=bookkeeper@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
