# Plaid credentials (https://dashboard.plaid.com/developers/keys)
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET_SANDBOX=your_sandbox_secret
PLAID_SECRET_PRODUCTION=your_production_secret
PLAID_ENV=sandbox

# OAuth return URL. Must be registered in the Plaid dashboard under
# "Allowed redirect URIs". Required in production for Chase / AMEX.
PLAID_REDIRECT_URI=http://localhost:3000/oauth-return

# Google Sheets (Service Account JSON key). The sheet must be shared
# with GOOGLE_SERVICE_ACCOUNT_EMAIL as Editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL=bookkeeper@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Natal ledger spreadsheet
NATAL_SHEET_ID=10P-lX84sAOvVRAkAyvMmTMPhIYklf9Ma_C9rUCtODFM
